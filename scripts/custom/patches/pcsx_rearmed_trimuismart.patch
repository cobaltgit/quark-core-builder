+#ifdef MIYOO
+#include <arm_neon.h>
+
+static void miyoo_scaled_blit(int doffs, const void *src_, int w, int h,
+                              int sstride, int bgr24)
+{
+    const unsigned short *src = src_;
+    unsigned short *dst;
+
+    int dw = g_layer_w;
+    int dh = g_layer_h;
+
+    int sdl_w = plat_sdl_screen->w;
+    int sdl_h = plat_sdl_screen->h;
+    int dstride = plat_sdl_screen->pitch / 2;
+
+    int xoff = (sdl_w - dw) / 2;
+    int yoff = (sdl_h - dh) / 2;
+    if (xoff < 0) xoff = 0;
+    if (yoff < 0) yoff = 0;
+
+    if (SDL_MUSTLOCK(plat_sdl_screen))
+        SDL_LockSurface(plat_sdl_screen);
+
+    dst = (unsigned short *)plat_sdl_screen->pixels + yoff * dstride + xoff;
+
+    int scale2x = (dw == w * 2);
+    int scale1x = (dw == w);
+
+    static int xmap[1024];
+    static int ymap[1024];
+
+    if (!scale1x && !scale2x) {
+        for (int dx = 0; dx < dw; dx++)
+            xmap[dx] = dx * w / dw;
+    }
+    for (int dy = 0; dy < dh; dy++)
+        ymap[dy] = dy * h / dh;
+
+    static unsigned short linebuf[1024];
+    unsigned short *prev_row = NULL;
+    int last_sy = -1;
+
+    for (int dy = 0; dy < dh && (yoff + dy) < sdl_h; dy++) {
+        int sy = ymap[dy];
+        unsigned short *drow = dst + dy * dstride;
+
+        if (sy == last_sy && prev_row != NULL) {
+            memcpy(drow, prev_row, dw * 2);
+            continue;
+        }
+
+        last_sy = sy;
+        prev_row = drow;
+
+        const unsigned short *srow = src + sy * sstride;
+
+        if (bgr24)
+            bgr888_to_rgb565(linebuf, srow, w);
+        else
+            bgr555_to_rgb565(linebuf, srow, w);
+
+        if (scale2x) {
+            int dx = 0;
+
+            for (; dx <= w - 8; dx += 8) {
+                uint16x8_t v = vld1q_u16(&linebuf[dx]);
+
+                uint16x8x2_t z = vzipq_u16(v, v);
+
+                vst1q_u16(&drow[dx * 2 + 0], z.val[0]);
+                vst1q_u16(&drow[dx * 2 + 8], z.val[1]);
+            }
+
+            for (; dx < w; dx++) {
+                unsigned short px = linebuf[dx];
+                drow[dx * 2 + 0] = px;
+                drow[dx * 2 + 1] = px;
+            }
+        }
+        else if (scale1x) {
+            int dx = 0;
+
+            for (; dx <= w - 8; dx += 8) {
+                uint16x8_t v = vld1q_u16(&linebuf[dx]);
+                vst1q_u16(&drow[dx], v);
+            }
+
+            for (; dx < w; dx++)
+                drow[dx] = linebuf[dx];
+        }
+        else {
+            for (int dx = 0; dx < dw && (xoff + dx) < sdl_w; dx++) {
+                drow[dx] = linebuf[xmap[dx]];
+            }
+        }
+    }
+
+    if (SDL_MUSTLOCK(plat_sdl_screen))
+        SDL_UnlockSurface(plat_sdl_screen);
+}
+#endif
